						{
							"name": "login",
							"item": [
								{
									"name": "/api/Auth/login",
									"event": [
										{
											"listen": "test",
											"script": {
												"exec": [
													"// Save bearerToken from successful register response and assert outcomes\r",
													"pm.test(\"Response status is 200 or 201\", function () {\r",
													"  pm.expect(pm.response.code, \"Unexpected status code\").to.be.oneOf([200, 201]);\r",
													"});\r",
													"\r",
													"(function handleTokenStorage() {\r",
													"  const isSuccess = [200, 201].includes(pm.response.code);\r",
													"  let json;\r",
													"  try {\r",
													"    json = pm.response.json();\r",
													"  } catch (e) {\r",
													"    json = null;\r",
													"  }\r",
													"\r",
													"  if (isSuccess && json && typeof json === 'object') {\r",
													"    const token = json.token;\r",
													"\r",
													"    pm.test(\"Token is present in response body\", function () {\r",
													"      pm.expect(token, \"'token' field missing in response body\").to.exist;\r",
													"      pm.expect(token, \"'token' must be a non-empty string\").to.be.a('string').and.not.empty;\r",
													"    });\r",
													"\r",
													"    if (typeof token === 'string' && token.length > 0) {\r",
													"      pm.environment.set('bearerToken', token);\r",
													"      pm.test(\"Environment variable 'bearerToken' set\", function () {\r",
													"        pm.expect(pm.environment.get('bearerToken')).to.eql(token);\r",
													"      });\r",
													"    }\r",
													"  } else {\r",
													"    pm.test(\"Request unsuccessful or invalid JSON response\", function () {\r",
													"      pm.expect.fail(`Request was not successful (status ${pm.response.code}) or response is not valid JSON`);\r",
													"    });\r",
													"  }\r",
													"})();"
												],
												"type": "text/javascript",
												"packages": {},
												"requests": {}
											}
										}
									],
